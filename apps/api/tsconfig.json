{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["@cloudflare/workers-types"],

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@app/db": ["../../packages/db/src/index.ts"],
      "@app/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
