# Profitmuna Web Environment Variables
# Copy to apps/web/.env.local for local development.

# Server-to-server base URL the Next.js BFF proxy uses to reach the Workers API.
# Intentionally NOT NEXT_PUBLIC_ — auth traffic never goes API-direct from the
# browser; it flows browser -> same-origin BFF (/api/auth/*) -> Workers API.
API_BASE_URL=http://localhost:8793

# NEXT_PUBLIC_API_URL remains in the root .env.example for non-auth, public API
# calls (exposed to the browser bundle — never put secrets in NEXT_PUBLIC_ vars).
