
# Profitmuna Main Environment Variables
# Copy this file to .env and fill in values.
# Restart Claude Code after editing .env / .mcp.json so MCPs pick up the new values.


# ──────────────────────────────────────────────────────────
# Cloudflare (Workers + D1)
# ──────────────────────────────────────────────────────────

# 1. CLOUDFLARE_ACCOUNT_ID
#    1. Sign in at https://dash.cloudflare.com
#    2. The URL becomes https://dash.cloudflare.com/<ACCOUNT_ID>/... — copy the hash.
#    3. Or: right sidebar → API → Account ID → click copy.
CLOUDFLARE_ACCOUNT_ID=

# 2. CLOUDFLARE_API_TOKEN  (Workers + D1 scope)
#    1. Top-right avatar → My Profile → API Tokens
#       (direct: https://dash.cloudflare.com/profile/api-tokens)
#    2. Create Token → Create Custom Token (NOT a Global API Key).
#    3. Name: profitmuna-main-deploy
#    4. Permissions — add these rows:
#         - Account → Workers Scripts     → Edit
#         - Account → D1                  → Edit
#         - Account → Workers R2 Storage  → Edit   (optional, only if R2 is added later)
#         - User    → User Details        → Read
#    5. Account Resources: Include → <your account>
#    6. TTL: leave open (or set ~1 year).
#    7. Continue to summary → Create Token → copy it (shown once).
CLOUDFLARE_API_TOKEN=

# 3. D1_DATABASE_ID
#    Create via Wrangler (NOT the UI) so the binding metadata lands in apps/api/wrangler.toml:
#       cd apps/api
#       npx wrangler login                          # opens browser, auth once
#       npx wrangler d1 create profitmuna-main-db
#    The output includes a [[d1_databases]] block — copy `database_id` into:
#       - apps/api/wrangler.toml  (replace the placeholder block)
#       - this .env as D1_DATABASE_ID=...
D1_DATABASE_ID=






# ──────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────

# 7. NODE_ENV
#    Standard Node env flag. Use `development` locally, `production` in deployed builds.
#    Next.js, wrangler, and most tooling branch on this automatically.
NODE_ENV=development


# 8. NEXT_PUBLIC_API_URL
#    URL the web app (apps/web) uses to reach the API.

#    - Local dev:  http://localhost:8793                  (`wrangler dev --port 8793`)
#    - Deployed:   https://<your-worker-subdomain>.workers.dev
#                  or your bound custom domain from wrangler.toml.

#    Prefix NEXT_PUBLIC_ exposes it to the browser bundle — do not store secrets here.

NEXT_PUBLIC_API_URL=http://localhost:8793







# ──────────────────────────────────────────────────────────
# Authentication (apps/api — Cloudflare Workers)
# Local dev: place these in apps/api/.dev.vars (wrangler reads it).
# Production: set secrets via `wrangler secret put <NAME>`.
# ──────────────────────────────────────────────────────────

# JWT signing secrets (HS256). Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Resend (transactional email: verification, welcome, password reset)
# Dashboard -> API Keys -> Create API Key
RESEND_API_KEY=
# Use onboarding@resend.dev for dev; verify a domain for production
RESEND_FROM_EMAIL=onboarding@resend.dev

# Google OAuth (Google Cloud Console -> Credentials -> OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an Authorized redirect URI on the OAuth client
GOOGLE_REDIRECT_URI=http://localhost:8793/api/auth/google/callback

# Base URL of the web app — used to build email links (verify/reset)
APP_BASE_URL=http://localhost:3006

# Server-to-server base URL the Next.js BFF uses to reach the Workers API
# (NOT NEXT_PUBLIC — never exposed to the browser)
API_BASE_URL=http://localhost:8793


# ──────────────────────────────────────────────────────────
# AI providers (fill only what you use)
# ──────────────────────────────────────────────────────────

# 11. ANTHROPIC_API_KEY
#    1. Sign in at https://console.anthropic.com/
#    2. Left sidebar → API Keys → Create Key.
#    3. Name it (e.g. profitmuna-main-local) and pick a workspace.
#    4. Copy the key (starts with `sk-ant-…`) — shown once.
#    5. The workspace must have billing configured, otherwise requests 401/402.
ANTHROPIC_API_KEY=

# 12. OPENAI_API_KEY
#    1. Go to https://platform.openai.com/api-keys
#    2. Create new secret key → pick project → Create.
#    3. Copy the key (starts with `sk-…`) — shown once.
#    4. The project must have billing/credits, otherwise requests 429.
OPENAI_API_KEY=



