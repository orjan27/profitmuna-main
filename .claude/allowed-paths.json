{
  "$comment": "Declarative file-placement contract enforced by .claude/hooks/folder-structure-guard.js. Keep in sync with CLAUDE.md 'Project Structure (STRICT)'. Edits to existing files are always allowed; this file controls where NEW files may be created.",
  "allowedGlobs": [
    "apps/api/src/routes/**",
    "apps/api/src/middleware/**",
    "apps/api/src/services/**",
    "apps/api/src/schemas/**",
    "apps/api/src/lib/**",
    "apps/api/src/types/**",
    "apps/api/tests/**",
    "apps/api/*.json",
    "apps/api/*.ts",
    "apps/api/*.toml",
    "apps/api/*.md",
    "packages/db/src/**",
    "packages/db/migrations/**",
    "packages/db/*.json",
    "packages/db/*.ts",
    "packages/db/*.md",

    "apps/web/src/app/**",
    "apps/web/src/components/**",
    "apps/web/src/hooks/**",
    "apps/web/src/server/**",
    "apps/web/src/lib/**",
    "apps/web/src/types/**",
    "apps/web/src/styles/**",
    "apps/web/public/**",
    "apps/web/*.json",
    "apps/web/*.ts",
    "apps/web/*.mjs",
    "apps/web/*.cjs",
    "apps/web/*.md",
    "apps/web/.env.example",
    ".claude/**",
    ".scaffold/**",
    "scripts/**",
    "docs/**",
    "*.json",
    "*.mjs",
    "*.cjs",
    "*.js",
    "*.ts",
    ".gitignore",
    ".nvmrc",
    ".env.example",
    ".env.sample"
  ],
  "forbiddenGlobs": [
    "apps/*/src/utils/**",
    "apps/*/src/helpers/**",
    "apps/*/src/common/**",
    "apps/*/src/shared/**",
    "apps/*/src/misc/**",
    "src/**",
    "lib/**",
    "utils/**",
    "helpers/**",
    "common/**"
  ],
  "rootOnlyFiles": [
    "README.md",
    "CLAUDE.md",
    "STANDARDS.md",
    "AGENTS.md",
    "PLUGINS-TO-INSTALL.md",
    "package.json",
    "package-lock.json",
    "tsconfig.base.json",
    "turbo.json",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml",
    "yarn.lock",
    ".prettierrc.json",
    ".prettierignore",
    ".eslintrc.json",
    ".editorconfig",
    ".gitattributes",
    ".env.example",
    ".mcp.json"
  ],
  "exemptRootMd": [
    "CLAUDE.md",
    "README.md",
    "AGENTS.md",
    "STANDARDS.md",
    "PLUGINS-TO-INSTALL.md"
  ]
}
